# Negative: duplicate interface name+version
# Expected errors:
#   Duplicate interface definition 'OrderRequest'
#   Duplicate interface definition 'OrderRequest@v2'

interface OrderRequest {
    order_id: String
}

interface OrderRequest {
    id: String
}

interface OrderRequest @v2 {
    order_id: String
    currency: String
}

interface OrderRequest @v2 {
    order_id: String
    version: Int
}
