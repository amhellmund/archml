# Negative: field types reference undefined names
# Expected errors:
#   Undefined type 'OrderStatus' in field 'status' of type 'Order'
#   Undefined type 'OrderItem' in field 'items' of type 'Order'
#   Undefined type 'UnknownMeta' in field 'meta' of interface 'Response'
#   Undefined type 'BadKey' in field 'labels' of interface 'Catalog'

type Order {
    order_id: String
    status: OrderStatus
    items: List<OrderItem>
    amount: Float
}

interface Response {
    id: String
    meta: Optional<UnknownMeta>
}

interface Catalog {
    labels: Map<BadKey, String>
}
