// Negative: via references point to non-existent channels
// Expected errors:
//   component 'Processor': via binding 'ghost_ch' refers to unknown channel
//   component 'Worker': via binding 'missing_ch' refers to unknown channel

interface DataFeed {
    field payload: String
}

interface Signal {
    field value: Int
}

system Pipeline {
    channel data_in: DataFeed

    component Consumer {
        requires DataFeed via ghost_ch
    }
}

component Router {
    channel signal_ch: Signal

    component Input {
        provides Signal via missing_ch
    }
}
