// Negative: connect and expose statements reference non-existent child entities
// Expected errors:
//   system 'Pipeline': connect references unknown child entity 'Ghost'
//   component 'Router': expose references unknown child entity 'Missing'

interface DataFeed {
    field payload: String
}

interface Signal {
    field value: Int
}

system Pipeline {
    component Consumer {
        requires DataFeed
    }

    connect Ghost.DataFeed -> Consumer.DataFeed
}

component Router {
    component Input {
        provides Signal
    }

    expose Missing.Signal
}
