# Negative: duplicate field names within a type and an interface
# Expected errors:
#   Duplicate field name 'street' in type 'Address'
#   Duplicate field name 'order_id' in interface 'OrderRequest'

type Address {
    street: String
    city: String
    street: String
    country: String
}

interface OrderRequest {
    order_id: String
    customer_id: String
    order_id: Int
    amount: Float
}
