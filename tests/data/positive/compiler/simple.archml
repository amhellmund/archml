# A self-contained .archml file with no external imports.

enum Status {
    Active
    Inactive
}

type Config {
    timeout: Int
    enabled: Bool
}

interface DataRequest {
    id: String
    config: Config
}

interface DataResponse {
    id: String
    status: Status
}

component Worker {
    requires DataRequest
    provides DataResponse
}

system SimpleSystem {
    channel data_req: DataRequest

    component Client {
        requires DataRequest via data_req
    }
    component WorkerInst {
        requires DataRequest via data_req
        provides DataResponse
    }
}
