# A self-contained .archml file with no external imports.

enum Status {
    Active
    Inactive
}

type Config {
    timeout: Int
    enabled: Bool
}

interface DataRequest {
    id: String
    settings: Config
}

interface DataResponse {
    id: String
    status: Status
}

component Worker {
    requires DataRequest
    provides DataResponse
}

system SimpleSystem {
    channel data_req: DataRequest

    component Client {
        provides DataRequest
    }
    component WorkerInst {
        requires DataRequest
        provides DataResponse
    }

    connect Client.DataRequest -> $data_req -> WorkerInst.DataRequest
}
