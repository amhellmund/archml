# Versioned interfaces: multiple versions of the same interface
# Expected result: no semantic errors

# Unversioned baseline
interface OrderRequest {
    field order_id: String
    field amount: Float
}

# Version 2 adds currency
interface OrderRequest @v2 {
    field order_id: String
    field amount: Float
    field currency: String
}

# Version 3 adds shipping
interface OrderRequest @v3 {
    field order_id: String
    field amount: Float
    field currency: String
    field shipping_method: String
}

# Component referencing specific version
component LegacyOrderService {
    requires OrderRequest
}

component OrderServiceV2 {
    requires OrderRequest @v2 as request_in
    provides OrderRequest @v3 as request_out
}

component ModernOrderService {
    requires OrderRequest @v3
}
