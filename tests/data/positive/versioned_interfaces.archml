# Variant-annotated interfaces: multiple deployment variants of the same interface
# Expected result: no semantic errors

interface OrderRequest {
    order_id: String
    amount: Float
}

interface OrderRequestExtended {
    order_id: String
    amount: Float
    currency: String
    shipping_method: String
}

# Components referencing specific interface variants
component LegacyOrderService {
    requires OrderRequest
}

component ModernOrderService {
    requires OrderRequestExtended as request_in
    provides OrderRequest as request_out
}
