# Source file for multi-file import tests
# This file defines types, enums, and interfaces that can be imported

enum OrderStatus {
    Pending
    Confirmed
    Shipped
    Delivered
    Cancelled
}

type OrderItem {
    product_id: String
    quantity: Int
    unit_price: Float
}

interface OrderRequest {
    order_id: String
    customer_id: String
    items: List<OrderItem>
}

interface OrderConfirmation {
    order_id: String
    status: OrderStatus
    confirmed_at: Timestamp
}

interface PaymentRequest {
    order_id: String
    amount: Float
    currency: String
}
