# Interface definitions with versioning and type references
# Expected result: no semantic errors

enum OrderStatus {
    Pending
    Confirmed
    Shipped
    Delivered
    Cancelled
}

type OrderItem {
    product_id: String
    quantity: Int
    unit_price: Float
}

# Unversioned interface
interface OrderRequest {
    """Payload for placing a new customer order."""

    order_id: String
    customer_id: String
    items: List<OrderItem>
    total_amount: Float
    currency: String
}

# Versioned interface v2 (adds shipping_method)
interface OrderRequest @v2 {

    order_id: String
    customer_id: String
    items: List<OrderItem>
    total_amount: Float
    currency: String
    shipping_method: String
}

interface OrderConfirmation {

    order_id: String
    status: OrderStatus
    confirmed_at: Timestamp
    estimated_delivery: Optional<Datetime>
}

interface PaymentRequest {
    order_id: String
    amount: Float
    currency: String
}

interface PaymentResult {
    order_id: String
    success: Bool
    transaction_id: Optional<String>
    error_message: Optional<String>
}

interface InventoryCheck {
    product_id: String
    requested_quantity: Int
}

interface InventoryStatus {
    product_id: String
    available: Bool
    available_quantity: Int
}

interface ReportOutput {
    report: String
    export: String
    artifact: String
}
