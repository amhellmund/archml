# Nested components with internal connections
# Expected result: no semantic errors

interface ValidationResult {
    is_valid: Bool
    errors: List<String>
}

interface OrderRequest {
    order_id: String
    amount: Float
}

interface OrderConfirmation {
    order_id: String
    confirmed: Bool
}

interface PaymentRequest {
    order_id: String
    amount: Float
}

# A component with sub-components and internal routing
component OrderService {
    """Accepts, validates, and processes customer orders."""

    component Validator {
        """Validates incoming order requests."""

        requires OrderRequest
        provides ValidationResult
    }

    component Processor {
        """Processes validated orders and triggers payment."""

        requires ValidationResult
        requires PaymentRequest
        provides OrderConfirmation
    }

    connect Validator.ValidationResult -> $validation -> Processor.ValidationResult

    expose Validator.OrderRequest
    expose Processor.PaymentRequest
    expose Processor.OrderConfirmation
}
